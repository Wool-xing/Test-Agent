# 行尾规范化
* text=auto eol=lf

# 文本文件强制 LF
*.md text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ini text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.example text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.env.example text eol=lf
LICENSE text eol=lf

# Windows 脚本保留 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
*.pptx binary
*.zip binary
*.tar.gz binary
*.exe binary
*.dll binary
*.dylib binary
*.so binary
*.apk binary
*.ipa binary
*.dmg binary
*.jmx binary
*.har binary
# LFS disabled — git-lfs not installed on all dev machines
# *.png filter=lfs diff=lfs merge=lfs -text
# *.jpg filter=lfs diff=lfs merge=lfs -text

# linguist（GitHub 语言识别）
05-代码示例/* linguist-language=Python
*.md linguist-documentation
06-CICD集成/*.yml linguist-language=YAML
06-CICD集成/*.groovy linguist-language=Groovy

# 合并策略
CHANGELOG.md merge=union
