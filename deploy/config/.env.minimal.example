# Test-Agent minimal config — copy to .env and fill in values.
# See .env.example for full reference (318 lines, all options).

# ── Required: LLM ──
TAGENT_LLM_PROVIDER=claude
TAGENT_LLM_API_KEY=sk-your-key-here

# ── Optional: paths ──
# TAGENT_LANG=zh                  # zh / en / zh-en (default: auto-detect)
# TAGENT_OUTPUT_DIR=workspace/test-reports

# ── Optional: persistence ──
# TAGENT_DB_URL=sqlite:///workspace/tagent.db
# TAGENT_MINIO_ENDPOINT=localhost:9000
