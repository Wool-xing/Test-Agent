# Test-Agent 最小配置 — 复制为 .env，填值即用。
# 完整选项参考: .env.example

# LLM Provider（必填）
TAGENT_LLM_PROVIDER=claude
TAGENT_LLM_API_KEY=sk-your-key-here

# 可选覆盖
# TAGENT_LLM_API_BASE=           # 中转站 / 代理 / 本地端点
# TAGENT_LLM_MODEL=              # 模型名（不填用 provider 默认）
# TAGENT_LLM_HEAVY_MODEL=        # 重任务模型（可选）
# TAGENT_LLM_PROVIDER_FALLBACK=ollama
# TAGENT_EMBED_PROVIDER=         # 默认复用 LLM provider

# 项目
PROJECT_NAME=default
# TEST_ENV=test

# 被测对象（至少填一组）
# TEST_APP_URL=http://test.example.com
# TEST_API_URL=http://test-api.example.com
