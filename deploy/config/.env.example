# Test-Agent 环境配置
# 复制为 .env 并填入实际值。.env 不要提交到版本控制。

# ══════════════════════════════════════════════════════════════
# LLM Provider（必填）
# ══════════════════════════════════════════════════════════════
# provider — 任意 LiteLLM 兼容的 provider ID
#   官方：openai | anthropic | deepseek | gemini | zhipu | qwen | ...
#   中转站/代理：配 TAGENT_LLM_API_BASE
#   本地：ollama | vllm | llamacpp | ...
TAGENT_LLM_PROVIDER=claude

# API key — 你 provider 对应的 key
TAGENT_LLM_API_KEY=sk-your-key-here

# 自定义 API 端点（中转站 / 代理 / 本地部署时填写）
# TAGENT_LLM_API_BASE=https://your-proxy.com/v1

# 模型覆盖（可选，不填则用 provider 默认模型）
# TAGENT_LLM_MODEL=deepseek-chat          # 主模型（light + heavy 共用）
# TAGENT_LLM_HEAVY_MODEL=deepseek-reasoner  # 重任务专用（可选，回退到 LLM_MODEL）

# 回退 provider（主 provider 不可用时自动切换）
# TAGENT_LLM_PROVIDER_FALLBACK=ollama
# TAGENT_LLM_MODEL_FALLBACK=qwen2.5:7b

# 超时 & 重试
# TAGENT_LLM_TIMEOUT_SECONDS=60
# TAGENT_LLM_MAX_RETRIES=2

# Embedding（可选，默认复用 LLM provider 和 key）
# TAGENT_EMBED_PROVIDER=openai
# TAGENT_EMBED_API_KEY=sk-xxx
# TAGENT_EMBED_API_BASE=
# TAGENT_EMBED_MODEL=text-embedding-3-small

# ══════════════════════════════════════════════════════════════
# 项目 & 路径
# ══════════════════════════════════════════════════════════════
PROJECT_NAME=default
TAGENT_EXPERTS_DIR=agents
TAGENT_SKILLS_DIR=skills
# APP_SRC_PATH=./src         # 被测系统源码路径（覆盖率指向）

# ══════════════════════════════════════════════════════════════
# 测试执行
# ══════════════════════════════════════════════════════════════
TEST_ENV=test                 # test | staging（禁止用 prod）
HEADLESS=true                 # true=无头 false=有界面
PARALLEL_WORKERS=4
TEST_TIMEOUT=120
COVERAGE_THRESHOLD=80
LOG_LEVEL=INFO

# 性能测试
# PERF_MODE=ci_quick          # full | ci_quick
# PERF_REGRESSION_MAX_PCT=20
# MAX_AFFECTED_MODULES_FULL_REGRESSION=3
# SOAK_HOURS=24

# ══════════════════════════════════════════════════════════════
# 被测环境（按 TEST_ENV 二选一填写）
# ══════════════════════════════════════════════════════════════
# --- test ---
# TEST_APP_URL=http://test.example.com
# TEST_API_URL=http://test-api.example.com
# TEST_DB_HOST=localhost
# TEST_DB_PORT=5432
# TEST_DB_NAME=testdb
# TEST_DB_USER=testuser
# TEST_DB_PASSWORD=
# TEST_REDIS_HOST=localhost
# TEST_REDIS_PORT=6379

# --- staging ---
# STAGING_APP_URL=http://staging.example.com
# STAGING_API_URL=http://staging-api.example.com
# STAGING_DB_HOST=staging-db.example.com
# STAGING_DB_PORT=5432
# STAGING_DB_NAME=stagingdb
# STAGING_DB_USER=staginguser
# STAGING_DB_PASSWORD=
# STAGING_REDIS_HOST=staging-redis.example.com
# STAGING_REDIS_PORT=6379

# ══════════════════════════════════════════════════════════════
# 测试账号（功能用例 fixture 用）
# ══════════════════════════════════════════════════════════════
# TEST_USER=testuser@example.com
# TEST_PASS=Test@123456
# ADMIN_USER=admin@example.com
# ADMIN_PASS=Admin@123456
# PERF_TEST_USER=perf_user
# PERF_TEST_PASS=PerfTest@123456

# ══════════════════════════════════════════════════════════════
# Bug Tracker & 通知（按需启用一个）
# ══════════════════════════════════════════════════════════════
# BUG_TRACKER=                # zentao | jira | github | linear | webhook
# ZENTAO_BASE_URL=http://your-zentao.com/zentao/api.php/v1
# ZENTAO_ACCOUNT=your_account
# ZENTAO_PASSWORD=your_password
# JIRA_URL=
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# JIRA_PROJECT=
# GITHUB_TOKEN=
# GITHUB_REPO=
# LINEAR_API_KEY=
# LINEAR_TEAM_ID=

# 通知 Webhook（任意 1 个生效即可）
# WECHAT_WEBHOOK_URL=
# FEISHU_WEBHOOK_URL=
# DINGTALK_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=
# TEAMS_WEBHOOK_URL=
# SERVERCHAN_SENDKEY=

# ══════════════════════════════════════════════════════════════
# 平台测试扩展（按需填写，不填的自动跳过）
# ══════════════════════════════════════════════════════════════
# --- 移动端 ---
# APPIUM_SERVER_URL=http://localhost:4723
# ANDROID_DEVICE=emulator-5554

# --- 桌面端 ---
# WIN_APP_PATH=

# --- 视觉/游戏 ---
# AIRTEST_DEVICE_URI=

# --- 车载 ---
# IOT_SERIAL_PORT=
# IOT_SERIAL_BAUDRATE=115200

# --- AI/ML ---
# AI_INFERENCE_URL=
# AI_GOLDEN_TEST_SET=workspace/自动化脚本/python/ai/datasets/golden_test.csv

# --- 安全 ---
# ZAP_API_KEY=
# ZAP_API_URL=http://localhost:8080

# --- 弱网 ---
# TOXIPROXY_URL=http://localhost:8474

# ══════════════════════════════════════════════════════════════
# Runtime 门控（安全操作需显式 opt-in）
# ══════════════════════════════════════════════════════════════
# TAGENT_PENTEST_AUTHORIZED=1
# TAGENT_CHAOS_AUTHORIZED=1
# TAGENT_PII_SALT=your-salt-here

# ══════════════════════════════════════════════════════════════
# 其他
# ══════════════════════════════════════════════════════════════
# MOCK_SERVER_URL=http://localhost:8080
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# RUN_ID=
