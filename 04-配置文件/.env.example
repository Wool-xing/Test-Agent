# 测试环境配置模板
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件不要提交到版本控制

# ===== 当前测试环境（test | staging）=====
# 注：禁止使用 prod 作为测试目标
TEST_ENV=test

# ===== 测试环境（test）应用配置 =====
TEST_APP_URL=http://test.example.com
TEST_API_URL=http://test-api.example.com

# ===== Staging 环境应用配置 =====
STAGING_APP_URL=http://staging.example.com
STAGING_API_URL=http://staging-api.example.com

# ===== 数据库（test）=====
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=testdb
TEST_DB_USER=testuser
TEST_DB_PASSWORD=testpassword

# ===== 数据库（staging）=====
STAGING_DB_HOST=staging-db.example.com
STAGING_DB_PORT=5432
STAGING_DB_NAME=stagingdb
STAGING_DB_USER=staginguser
STAGING_DB_PASSWORD=

# ===== Redis =====
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6379
STAGING_REDIS_HOST=staging-redis.example.com
STAGING_REDIS_PORT=6379

# ===== Mock 服务（wiremock 等）=====
MOCK_SERVER_URL=http://localhost:8080

# ===== 测试账号（功能用例 fixture 使用）=====
TEST_USER=testuser@example.com
TEST_PASS=Test@123456
ADMIN_USER=admin@example.com
ADMIN_PASS=Admin@123456

# ===== 性能压测专用账号 =====
PERF_TEST_USER=perf_user
PERF_TEST_PASS=PerfTest@123456

# ===== 禅道（按环境隔离，可选填二选一）=====
ZENTAO_BASE_URL=http://your-zentao.com/zentao/api.php/v1
TEST_ZENTAO_URL=
STAGING_ZENTAO_URL=
ZENTAO_ACCOUNT=your_zentao_account
ZENTAO_PASSWORD=your_zentao_password

# ===== 通知 Webhook（直连方式，curl/SDK 调用）=====
# 企业微信群机器人 webhook
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key
# 飞书自定义机器人 webhook
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-token
# 钉钉自定义机器人 webhook
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token

# ===== 通知 - 应用消息（如需要使用 corp 应用消息而非群机器人，可填）=====
WECHAT_CORP_ID=
WECHAT_AGENT_ID=
WECHAT_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ===== 测试执行配置 =====
HEADLESS=true              # true=无头模式，false=有界面（调试时用）
PARALLEL_WORKERS=4         # 并行进程数（pytest -n 读取）
TEST_TIMEOUT=120           # 单用例超时（秒）
COVERAGE_THRESHOLD=80      # 覆盖率门禁（%）

# ===== 性能测试模式 =====
# full = 50 并发完整压测（手动/release触发）
# ci_quick = 5 并发快速验证（CI 默认）
PERF_MODE=ci_quick
# 性能基线对比上限（百分比）
PERF_REGRESSION_MAX_PCT=20

# ===== 回归测试 =====
# 受影响模块超过此数量时触发全量回归
MAX_AFFECTED_MODULES_FULL_REGRESSION=3

# ===== 被测系统源码路径（用于 pytest-cov，覆盖率指标真正指向被测代码）=====
# 示例：./src 或 ./app
APP_SRC_PATH=./src

# ===== 日志级别: DEBUG | INFO | WARNING | ERROR =====
LOG_LEVEL=INFO

# ============================================================
# 扩展平台测试（移动 / 桌面 / 视觉 / 系统集成 / AI）
# 按实际需要启用对应字段，无需的子集留空即可
# ============================================================

# ===== 移动端（mobile-tester） =====
APPIUM_SERVER_URL=http://localhost:4723
ANDROID_DEVICE=emulator-5554
ANDROID_APP_PATH=
ANDROID_PACKAGE=
ANDROID_ACTIVITY=
IOS_DEVICE_UDID=
IOS_DEVICE_NAME=iPhone 15
IOS_PLATFORM_VERSION=17.0
IOS_APP_PATH=
IOS_BUNDLE_ID=
# 云真机（可选，二选一）
SAUCELABS_USERNAME=
SAUCELABS_ACCESS_KEY=
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
# 微信小程序
WX_DEVTOOL_CLI=
WX_PROJECT_PATH=
WX_APP_ID=

# ===== 桌面（desktop-tester） =====
WIN_APP_PATH=
MAC_APP_NAME=
MAC_APP_PATH=
LINUX_APP_BIN=
ELECTRON_APP_PATH=

# WebSocket（EXE / Web / 移动 WS 协议层测试通用）
WS_URL=ws://server.example.com/socket
WS_TOKEN=
WS_PING_INTERVAL=30

# ===== 视觉/游戏（visual-tester） =====
AIRTEST_DEVICE_URI=
OCR_ENGINE=tesseract
TESSERACT_CMD=
TESSERACT_LANG=chi_sim+eng
VISUAL_SIMILARITY_THRESHOLD=0.95

# ===== 系统集成（system-tester） =====
# IoT
IOT_SSH_HOST=
IOT_SSH_USER=
IOT_SSH_PASSWORD=
IOT_SERIAL_PORT=
IOT_SERIAL_BAUDRATE=115200
IOT_MQTT_BROKER=
IOT_MQTT_PORT=1883
# 链路追踪
JAEGER_BASE_URL=
ZIPKIN_BASE_URL=
# 消息队列
KAFKA_BROKERS=
RABBITMQ_URL=
# 音视频
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# ===== AI/ML（ai-tester） =====
AI_INFERENCE_URL=
AI_MODEL_VERSION=
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
AI_GOLDEN_TEST_SET=workspace/自动化脚本/python/ai/datasets/golden_test.csv
AI_DRIFT_BASELINE=workspace/自动化脚本/python/ai/datasets/drift_baseline.csv
